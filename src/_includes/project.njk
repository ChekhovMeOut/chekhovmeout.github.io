---
layout: base.njk
---

{% if hero %}
<div class="article-hero{% if heroMode == 'scale-to-width' %} hero-scale-to-width{% elif heroMode == 'scale-to-height' %} hero-scale-to-height{% endif %}"{% if heroBg %} style="background-color: {{ heroBg }};"{% endif %}>
  <img src="{{ hero }}" alt="{{ title }}" class="article-hero-img">
</div>
{% endif %}

<div class="container">
  <h2 class="job-title">{{ title }}</h2>

  <div class="metadata-grid">
    {% if date %}
    <div class="metadata-item">
      <span class="metadata-label">Date</span>
      <span class="metadata-value">{{ date }}</span>
    </div>
    {% endif %}
    {% if skills %}
    <div class="metadata-item">
      <span class="metadata-label">Skills</span>
      <div class="project-technologies">
        {%- for skill in skills -%}
          <span class="tech-tag">{{ skill }}</span>
        {%- endfor -%}
      </div>
    </div>
    {% endif %}
  </div>

  <div class="metadata-item" style="margin-bottom: var(--space-lg);">
    <span class="metadata-label">Summary</span>
    <span class="metadata-value">{{ description }}</span>
  </div>

  {{ content | safe }}
</div>
